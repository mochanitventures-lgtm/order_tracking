# App settings
PORT=3000
SESSION_SECRET=change_this_secret_in_prod

# Option 1: Local PostgreSQL or any PostgreSQL using individual fields
DB_HOST=localhost
DB_PORT=5432
DB_USER=odts_admin
DB_PASSWORD=admin123
DB_NAME=order_tracking
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Option 2: AWS RDS / managed PostgreSQL using one connection string
# If DATABASE_URL is set, it takes priority over DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME
# Example:
# DATABASE_URL=postgresql://postgres:yourPassword@your-rds-endpoint.region.rds.amazonaws.com:5432/order_tracking
DATABASE_URL=

# Optional pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# Firebase / other existing settings
FIREBASE_DATABASE_URL=
