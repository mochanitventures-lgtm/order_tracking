<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="/orders">My Orders</a></li>
    <li class="breadcrumb-item active">Place New Order</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
          <h4 class="mb-1">New Order</h4>
          <div class="text-muted small">Fill in the required details to place a new order.</div>
        </div>
        <a href="/orders" class="btn btn-outline-secondary btn-sm">Back to Orders</a>
      </div>
      <div class="card-body p-4">
        <div id="form-alert" class="alert d-none" role="alert"></div>

        <form id="new-order-form" class="row g-3">
          <div class="col-md-6">
            <label for="product_id" class="form-label fw-semibold">Product</label>
            <select id="product_id" name="product_id" class="form-select" required>
              <option value="">Loading products…</option>
            </select>
          </div>

          <div class="col-md-6">
            <label for="quantity" class="form-label fw-semibold">Quantity</label>
            <input id="quantity" name="quantity" type="text" class="form-control" placeholder="Enter quantity" required>
          </div>

          <!-- Party Section -->
          <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <label class="form-label fw-semibold mb-0">Ship to Party</label>
              <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="new-party-toggle">
                <label class="form-check-label small" for="new-party-toggle">Add New Party</label>
              </div>
            </div>

            <!-- Existing party -->
            <div id="existing-party-section">
              <select id="party_select" class="form-select" required>
                <option value="">Loading parties…</option>
              </select>
              <input type="hidden" id="party_id" name="party_id">
            </div>

            <!-- New party -->
            <div id="new-party-section" class="d-none">
              <div class="row g-2">
                <div class="col-12">
                  <input id="new_party_name" type="text" class="form-control" placeholder="Party / Company Name" autocomplete="off">
                </div>
                <div class="col-12">
                  <input id="new_party_phone" type="text" class="form-control" placeholder="Phone Number">
                </div>
                <div class="col-12">
                  <input id="new_party_address" type="text" class="form-control" placeholder="Address">
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-6">
            <label for="contact_number" class="form-label fw-semibold">Contact Number</label>
            <input id="contact_number" name="contact_number" type="text" class="form-control" placeholder="Auto-filled or enter manually">
          </div>

          <div class="col-12">
            <label for="delivery_address" class="form-label fw-semibold">Delivery Address</label>
            <textarea id="delivery_address" name="delivery_address" class="form-control" rows="2" placeholder="Auto-filled or enter manually"></textarea>
          </div>

          <div class="col-md-6">
            <label for="load_type_code" class="form-label fw-semibold">Loading Type</label>
            <select id="load_type_code" name="load_type_code" class="form-select" required>
              <option value="">Loading…</option>
            </select>
          </div>

          <div class="col-md-6">
            <label for="preferred_location_code" class="form-label fw-semibold">Preferred Loading Location</label>
            <select id="preferred_location_code" name="preferred_location_code" class="form-select" required>
              <option value="">Loading…</option>
            </select>
          </div>

          <div class="col-12 d-flex gap-2 justify-content-end pt-2">
            <a href="/orders" class="btn btn-light border">Cancel</a>
            <button type="submit" class="btn btn-primary" id="submit-btn">Place Order</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // Populate Product dropdown
  (async () => {
    const sel = document.getElementById('product_id');
    try {
      const res = await fetch('/api/dealer/products');
      const products = await res.json();
      sel.innerHTML = '<option value="">Select Product</option>';
      if (products.length === 0) {
        sel.innerHTML = '<option value="">No products available</option>';
      } else {
        products.forEach(p => {
          const opt = document.createElement('option');
          opt.value = p.product_id;
          opt.textContent = p.product_name;
          sel.appendChild(opt);
        });
      }
    } catch (e) {
      sel.innerHTML = '<option value="">Failed to load products</option>';
    }
  })();

  // Populate Loading Type dropdown (flat list, no groups)
  (async () => {
    const sel = document.getElementById('load_type_code');
    try {
      const res = await fetch('/api/codes/loading_type');
      const codes = await res.json();
      sel.innerHTML = '<option value="">Select Loading Type</option>';
      codes.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.code;
        opt.textContent = c.code_desc;
        sel.appendChild(opt);
      });
    } catch (e) {
      sel.innerHTML = '<option value="">Failed to load</option>';
    }
  })();

  // Populate Preferred Loading Location dropdown (grouped by code_label)
  (async () => {
    const sel = document.getElementById('preferred_location_code');
    try {
      const res = await fetch('/api/codes/loading_location');
      const codes = await res.json();
      sel.innerHTML = '<option value="">Select Preferred Location</option>';
      const groups = {};
      codes.forEach(c => {
        const grp = c.code_label || 'Other';
        if (!groups[grp]) groups[grp] = [];
        groups[grp].push(c);
      });
      Object.entries(groups).forEach(([label, items]) => {
        const og = document.createElement('optgroup');
        og.label = label.charAt(0) + label.slice(1).toLowerCase();
        items.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.code;
          opt.textContent = c.code_desc;
          og.appendChild(opt);
        });
        sel.appendChild(og);
      });
    } catch (e) {
      sel.innerHTML = '<option value="">Failed to load</option>';
    }
  })();

  // ── Party logic ──────────────────────────────────────────────────────────
  let partiesData = [];

  (async () => {
    const sel = document.getElementById('party_select');
    try {
      const res = await fetch('/api/dealer/parties');
      partiesData = await res.json();
      sel.innerHTML = '<option value="">Select Party</option>';
      if (partiesData.length === 0) {
        sel.innerHTML = '<option value="">No parties found</option>';
      } else {
        partiesData.forEach(p => {
          const opt = document.createElement('option');
          opt.value = p.party_id;
          opt.textContent = p.party_company_name;
          sel.appendChild(opt);
        });
      }
    } catch (e) {
      sel.innerHTML = '<option value="">Failed to load parties</option>';
    }
  })();

  // Auto-fill phone & address when existing party is selected
  document.getElementById('party_select').addEventListener('change', function () {
    const selected = partiesData.find(p => String(p.party_id) === this.value);
    document.getElementById('party_id').value = this.value;
    document.getElementById('contact_number').value = selected ? (selected.party_phone || '') : '';
    document.getElementById('delivery_address').value = selected ? (selected.party_address || '') : '';
  });

  // Sync new party phone → contact number field in real-time
  document.getElementById('new_party_phone').addEventListener('input', function () {
    document.getElementById('contact_number').value = this.value;
  });

  // Sync new party address → delivery address field in real-time
  document.getElementById('new_party_address').addEventListener('input', function () {
    document.getElementById('delivery_address').value = this.value;
  });

  // Toggle between existing and new party
  document.getElementById('new-party-toggle').addEventListener('change', function () {
    const isNew = this.checked;
    document.getElementById('existing-party-section').classList.toggle('d-none', isNew);
    document.getElementById('new-party-section').classList.toggle('d-none', !isNew);
    document.getElementById('party_select').required = !isNew;
    if (isNew) {
      document.getElementById('party_id').value = '';
      document.getElementById('contact_number').value = '';
      document.getElementById('delivery_address').value = '';
    } else {
      // Re-trigger auto-fill from selected existing party
      document.getElementById('party_select').dispatchEvent(new Event('change'));
    }
  });

  // ── Form submit ──────────────────────────────────────────────────────────
  const form = document.getElementById('new-order-form');
  const submitBtn = document.getElementById('submit-btn');
  const alertBox = document.getElementById('form-alert');

  function showAlert(type, message) {
    alertBox.className = `alert alert-${type}`;
    alertBox.textContent = message;
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    alertBox.className = 'alert d-none';
    alertBox.textContent = '';

    const isNew = document.getElementById('new-party-toggle').checked;
    let party_id = document.getElementById('party_id').value;

    try {
      // If adding a new party, create it first
      if (isNew) {
        const newName = document.getElementById('new_party_name').value.trim();
        if (!newName) throw new Error('Party name is required.');
        const pRes = await fetch('/api/dealer/parties', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            party_company_name: newName,
            party_phone: document.getElementById('new_party_phone').value.trim(),
            party_address: document.getElementById('new_party_address').value.trim(),
          }),
        });
        const pData = await pRes.json();
        if (!pRes.ok) throw new Error(pData.error || 'Failed to create party');
        party_id = pData.party_id;
      } else {
        if (!party_id) throw new Error('Please select a party.');
      }

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());
      payload.party_id = party_id;

      const response = await fetch('/api/dealer/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json();
      if (!response.ok) throw new Error(data.error || 'Failed to create order');

      showAlert('success', `Order #${data.order_id} placed successfully.`);
      window.setTimeout(() => { window.location.href = '/orders'; }, 800);
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Place Order';
    }
  });
</script>

<%- include('../partials/footer') %>