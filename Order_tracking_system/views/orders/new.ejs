<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="/orders">My Orders</a></li>
    <li class="breadcrumb-item active">Place New Order</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
          <h4 class="mb-1">Create New Order</h4>
          <div class="text-muted small">Fill in the required details to place a new order.</div>
        </div>
        <a href="/orders" class="btn btn-outline-secondary btn-sm">Back to Orders</a>
      </div>
      <div class="card-body p-4">
        <div id="form-alert" class="alert d-none" role="alert"></div>

        <form id="new-order-form" class="row g-3">
          <div class="col-md-6">
            <label for="product_name" class="form-label fw-semibold">Product</label>
            <select id="product_name" name="product_name" class="form-select" required>
              <option value="">Select Product</option>
              <option value="Gold">Gold</option>
              <option value="Suraksha Power">Suraksha Power</option>
              <option value="C+">C+</option>
            </select>
          </div>

          <div class="col-md-6">
            <label for="quantity" class="form-label fw-semibold">Quantity</label>
            <input id="quantity" name="quantity" type="text" class="form-control" placeholder="Enter quantity" required>
          </div>

          <div class="col-md-6">
            <label for="party_name" class="form-label fw-semibold">Ship to Party</label>
            <select id="party_name" name="party_name" class="form-select" required>
              <option value="">Loading parties…</option>
            </select>
          </div>

          <div class="col-md-6">
            <label for="contact_number" class="form-label fw-semibold">Contact Number</label>
            <input id="contact_number" name="contact_number" type="text" class="form-control" placeholder="Enter contact number" required>
          </div>

          <div class="col-12">
            <label for="delivery_address" class="form-label fw-semibold">Delivery Address</label>
            <textarea id="delivery_address" name="delivery_address" class="form-control" rows="3" placeholder="Enter delivery address" required></textarea>
          </div>

          <div class="col-md-6">
            <label for="loading_type" class="form-label fw-semibold">Loading Type</label>
            <select id="loading_type" name="loading_type" class="form-select" required>
              <option value="">Select Loading Type</option>
              <option value="Self DOT">Self DOT (Dealer own truck)</option>
              <option value="Company Transport">Company Transport</option>
            </select>
          </div>

          <div class="col-md-6">
            <label for="preferred_loading_location" class="form-label fw-semibold">Preferred Loading Location</label>
            <select id="preferred_loading_location" name="preferred_loading_location" class="form-select" required>
              <option value="">Select Preferred Loading Location</option>
              <optgroup label="Rake">
                <option value="Rake - Chaukhadi">Rake (Chaukhadi)</option>
                <option value="Rake - Shivpur">Rake (Shivpur)</option>
              </optgroup>
              <optgroup label="Warehouse">
                <option value="Warehouse - Tarna">Warehouse (Tarna)</option>
                <option value="Warehouse - Goenka">Warehouse (Goenka)</option>
                <option value="Warehouse - Bhupur">Warehouse (Bhupur)</option>
                <option value="Warehouse - Dafi">Warehouse (Dafi)</option>
                <option value="Warehouse - Other">Warehouse (Any other)</option>
              </optgroup>
              <optgroup label="SOW">
                <option value="SOW - Bhabhua">SOW (Bhabhua)</option>
                <option value="SOW - Tekaria">SOW (Tekaria)</option>
              </optgroup>
            </select>
          </div>

          <div class="col-12 d-flex gap-2 justify-content-end pt-2">
            <a href="/orders" class="btn btn-light border">Cancel</a>
            <button type="submit" class="btn btn-primary" id="submit-btn">Submit Order</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // Populate Ship to Party dropdown
  (async () => {
    const sel = document.getElementById('party_name');
    try {
      const res = await fetch('/api/dealer/parties');
      const parties = await res.json();
      sel.innerHTML = '<option value="">Select Party</option>';
      if (parties.length === 0) {
        sel.innerHTML = '<option value="">No parties available</option>';
      } else {
        parties.forEach(p => {
          const opt = document.createElement('option');
          opt.value = p.party_company_name;
          opt.textContent = p.party_company_name;
          sel.appendChild(opt);
        });
      }
    } catch (e) {
      sel.innerHTML = '<option value="">Failed to load parties</option>';
    }
  })();

  const form = document.getElementById('new-order-form');
  const submitBtn = document.getElementById('submit-btn');
  const alertBox = document.getElementById('form-alert');

  function showAlert(type, message) {
    alertBox.className = `alert alert-${type}`;
    alertBox.textContent = message;
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    alertBox.className = 'alert d-none';
    alertBox.textContent = '';

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/dealer/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json();
      if (!response.ok) throw new Error(data.error || 'Failed to create order');

      showAlert('success', `Order #${data.order_id} created successfully.`);
      window.setTimeout(() => {
        window.location.href = '/orders';
      }, 800);
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Order';
    }
  });
</script>

<%- include('../partials/footer') %>