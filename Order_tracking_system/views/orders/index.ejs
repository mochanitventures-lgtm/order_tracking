<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script>window._IS_ADMIN = <%- isAdmin ? 'true' : 'false' %>;</script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active"><%= isAdmin ? 'All Orders & Dispatch' : 'My Orders' %></li>
  </ol>
</nav>
<div id="app-root"></div>

<script type="text/babel">
const { useState, useEffect } = React;
const IS_ADMIN = window._IS_ADMIN === true;

const STATUS_CONFIG = {
  PENDING:    { color: 'warning',   text: 'Pending',     icon: '🕐' },
  CONFIRMED:  { color: 'info',      text: 'Confirmed',   icon: '✅' },
  DISPATCHED: { color: 'primary',   text: 'Dispatched',  icon: '📦' },
  IN_TRANSIT: { color: 'purple',    text: 'In Transit',  icon: '🚛' },
  DELIVERED:  { color: 'success',   text: 'Delivered',   icon: '🏁' },
  CANCELLED:  { color: 'secondary', text: 'Cancelled',   icon: '❌' },
};

const UNITS = ['MT', 'KG', 'NOS', 'PCS', 'TON'];

const EMPTY_FORM = { product_name: '', quantity: '', unit: 'MT', delivery_location: '', remarks: '' };

function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status] || { color: 'secondary', text: status };
  const style = status === 'IN_TRANSIT' ? { background: '#6f42c1', color: '#fff' } : {};
  return (
    <span className={`badge bg-${cfg.color}`} style={style}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function SummaryCard({ label, value, color, icon }) {
  return (
    <div className="col-6 col-md-3 mb-3">
      <div className={`card border-0 shadow-sm h-100`} style={{ borderLeft: `4px solid var(--bs-${color})` }}>
        <div className="card-body d-flex align-items-center gap-3 py-3">
          <div style={{ fontSize: '2rem' }}>{icon}</div>
          <div>
            <div className="fs-4 fw-bold">{value}</div>
            <div className="text-muted small">{label}</div>
          </div>
        </div>
      </div>
    </div>
  );
}

function DispatchModal({ order, onClose }) {
  if (!order) return null;
  const d = order.dispatch;
  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <div className="modal-header bg-primary text-white">
            <h5 className="modal-title">📋 Order #{order.order_id} — Dispatch Details</h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>
          <div className="modal-body">
            {/* Order Info */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Information</h6>
            <div className="row g-3 mb-4">
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Product</div>
                  <div className="fw-semibold">{order.product_name}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Quantity</div>
                  <div className="fw-semibold">{order.quantity} {order.unit}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Delivery Location</div>
                  <div className="fw-semibold">{order.delivery_location}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Order Date</div>
                  <div className="fw-semibold">{order.order_date}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Status</div>
                  <div><StatusBadge status={order.order_status}/></div>
                </div>
              </div>
              {order.remarks && (
                <div className="col-md-4">
                  <div className="p-3 bg-light rounded">
                    <div className="text-muted small">Remarks</div>
                    <div className="fw-semibold">{order.remarks}</div>
                  </div>
                </div>
              )}
            </div>

            {/* Dispatch Info */}
            {d ? (
              <>
                <h6 className="fw-bold text-muted mb-3 text-uppercase small">Dispatch Information</h6>
                <div className="row g-3">
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Dispatch ID</div>
                      <div className="fw-semibold">#{d.dispatch_id}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Dispatch Date</div>
                      <div className="fw-semibold">{d.dispatch_date}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Vehicle No.</div>
                      <div className="fw-semibold">{d.vehicle_no}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Driver Name</div>
                      <div className="fw-semibold">{d.driver_name}</div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Driver Phone</div>
                      <div className="fw-semibold">{d.driver_phone}</div>
                      <div className="d-flex gap-1 mt-2 flex-wrap">
                        <a
                          className="btn btn-sm btn-outline-primary"
                          href={`/tracking?driver=${encodeURIComponent(d.driver_phone)}&order=${order.order_id}`}
                        >
                          📍 Live Track
                        </a>
                        <button type="button" className="btn btn-sm btn-outline-secondary"
                          onClick={()=>{
                            const link = `${window.location.origin}/driver/track?phone=${encodeURIComponent(d.driver_phone)}&order=${order.order_id}&vehicle=${encodeURIComponent(d.vehicle_no||'')}`;
                            navigator.clipboard.writeText(link).then(()=>notify('Driver tracking link copied to clipboard!','success'));
                          }}>
                          🔗 Copy Driver Link
                        </button>
                      </div>
                    </div>
                  </div>
                  <div className="col-md-4">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Expected Delivery</div>
                      <div className="fw-semibold">{d.expected_delivery}</div>
                    </div>
                  </div>
                  {d.actual_delivery && (
                    <div className="col-md-4">
                      <div className="p-3 bg-success bg-opacity-10 rounded border border-success">
                        <div className="text-muted small">Actual Delivery</div>
                        <div className="fw-semibold text-success">{d.actual_delivery}</div>
                      </div>
                    </div>
                  )}
                </div>

                {/* Progress Tracker */}
                <div className="mt-4">
                  <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Progress</h6>
                  <div className="d-flex align-items-center gap-0 flex-wrap">
                    {['PENDING','CONFIRMED','DISPATCHED','IN_TRANSIT','DELIVERED'].map((s, i, arr) => {
                      const statuses = ['PENDING','CONFIRMED','DISPATCHED','IN_TRANSIT','DELIVERED'];
                      const currentIdx = statuses.indexOf(order.order_status);
                      const stepIdx = statuses.indexOf(s);
                      const done = stepIdx <= currentIdx;
                      const active = stepIdx === currentIdx;
                      return (
                        <React.Fragment key={s}>
                          <div className="d-flex flex-column align-items-center" style={{flex:'1',minWidth:'60px'}}>
                            <div style={{
                              width:32, height:32, borderRadius:'50%', display:'flex',
                              alignItems:'center', justifyContent:'center', fontSize:14,
                              background: done ? (active ? '#0d6efd' : '#198754') : '#dee2e6',
                              color: done ? '#fff' : '#6c757d', fontWeight:'bold'
                            }}>{done ? (active ? '●' : '✓') : (i+1)}</div>
                            <div className="text-center mt-1" style={{fontSize:'10px', color: done?'#198754':'#6c757d', fontWeight: active?'bold':'normal'}}>
                              {STATUS_CONFIG[s]?.text}
                            </div>
                          </div>
                          {i < arr.length - 1 && (
                            <div style={{flex:'1', height:3, background: stepIdx < currentIdx ? '#198754' : '#dee2e6', minWidth:10, marginBottom:18}}></div>
                          )}
                        </React.Fragment>
                      );
                    })}
                  </div>
                </div>
              </>
            ) : (
              <div className="alert alert-info mt-2 mb-0">
                <strong>Dispatch not yet initiated.</strong> Your order is being processed. Dispatch details will appear here once the order is confirmed and dispatched.
              </div>
            )}
          </div>
          <div className="modal-footer">
            <button className="btn btn-secondary" onClick={onClose}>Close</button>
          </div>
        </div>
      </div>
    </div>
  );
}

function PlaceOrderModal({ onClose, onSaved }) {
  const [form, setForm] = useState(EMPTY_FORM);
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState('');

  const submit = async (e) => {
    e.preventDefault();
    setSaving(true); setError('');
    try {
      const res = await fetch('/api/dealer/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(form)
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to place order');
      onSaved(data);
    } catch (err) {
      setError(err.message);
    } finally {
      setSaving(false);
    }
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered">
        <div className="modal-content">
          <form onSubmit={submit}>
            <div className="modal-header bg-primary text-white">
              <h5 className="modal-title">🛒 Place New Order</h5>
              <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
            </div>
            <div className="modal-body">
              {error && <div className="alert alert-danger py-2">{error}</div>}
              <div className="mb-3">
                <label className="form-label fw-semibold">Product Name <span className="text-danger">*</span></label>
                <input className="form-control" value={form.product_name}
                  onChange={e => setForm({ ...form, product_name: e.target.value })}
                  placeholder="e.g. Steel Pipes, TMT Bars" required />
              </div>
              <div className="row g-3 mb-3">
                <div className="col-8">
                  <label className="form-label fw-semibold">Quantity <span className="text-danger">*</span></label>
                  <input type="number" min="1" className="form-control" value={form.quantity}
                    onChange={e => setForm({ ...form, quantity: e.target.value })}
                    placeholder="Enter quantity" required />
                </div>
                <div className="col-4">
                  <label className="form-label fw-semibold">Unit</label>
                  <select className="form-select" value={form.unit}
                    onChange={e => setForm({ ...form, unit: e.target.value })}>
                    {UNITS.map(u => <option key={u}>{u}</option>)}
                  </select>
                </div>
              </div>
              <div className="mb-3">
                <label className="form-label fw-semibold">Delivery Location <span className="text-danger">*</span></label>
                <input className="form-control" value={form.delivery_location}
                  onChange={e => setForm({ ...form, delivery_location: e.target.value })}
                  placeholder="e.g. Mumbai - Godown" required />
              </div>
              <div className="mb-1">
                <label className="form-label fw-semibold">Remarks</label>
                <textarea className="form-control" rows="2" value={form.remarks}
                  onChange={e => setForm({ ...form, remarks: e.target.value })}
                  placeholder="Any special instructions…" />
              </div>
            </div>
            <div className="modal-footer">
              <button type="button" className="btn btn-secondary" onClick={onClose}>Cancel</button>
              <button type="submit" className="btn btn-primary" disabled={saving}>
                {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
                Place Order
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  );
}

function App() {
  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);
  const [search, setSearch] = useState('');
  const [statusFilter, setStatusFilter] = useState('ALL');
  const [selectedOrder, setSelectedOrder] = useState(null);
  const [showPlaceOrder, setShowPlaceOrder] = useState(false);
  const [toast, setToast] = useState({ msg: '', type: 'success' });
  const [sortCol, setSortCol] = useState('order_id');
  const [sortDir, setSortDir] = useState('desc');

  const toggleSort = (col) => {
    if (sortCol === col) {
      setSortDir(d => d === 'asc' ? 'desc' : 'asc');
    } else {
      setSortCol(col);
      setSortDir('asc');
    }
  };

  const SortTh = ({ col, children, style }) => {
    const active = sortCol === col;
    return (
      <th style={{ cursor: 'pointer', userSelect: 'none', whiteSpace: 'nowrap', ...style }}
          onClick={() => toggleSort(col)}>
        {children}&nbsp;
        <span style={{ opacity: active ? 1 : 0.3, fontSize: '0.75em' }}>
          {active ? (sortDir === 'asc' ? '▲' : '▼') : '▲▼'}
        </span>
      </th>
    );
  };

  const notify = (msg, type = 'success') => {
    setToast({ msg, type });
    setTimeout(() => setToast({ msg: '' }), 4000);
  };

  const load = async () => {
    setLoading(true);
    try {
      const endpoint = IS_ADMIN ? '/api/admin/orders' : '/api/dealer/orders';
      const r = await fetch(endpoint);
      if (!r.ok) throw new Error(await r.text());
      setOrders(await r.json());
    } catch (e) {
      notify(e.message, 'danger');
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => { load(); }, []);

  const counts = {
    total: orders.length,
    pending: orders.filter(o => o.order_status === 'PENDING').length,
    inTransit: orders.filter(o => o.order_status === 'IN_TRANSIT' || o.order_status === 'DISPATCHED').length,
    delivered: orders.filter(o => o.order_status === 'DELIVERED').length,
  };

  const filtered = orders.filter(o => {
    const matchSearch = (o.product_name + ' ' + o.delivery_location + ' ' + o.order_id)
      .toLowerCase().includes(search.toLowerCase());
    const matchStatus = statusFilter === 'ALL' || o.order_status === statusFilter;
    return matchSearch && matchStatus;
  });

  const sorted = [...filtered].sort((a, b) => {
    let av = a[sortCol] ?? '';
    let bv = b[sortCol] ?? '';
    // numeric sort for order_id and quantity
    if (sortCol === 'order_id' || sortCol === 'quantity') {
      av = Number(av); bv = Number(bv);
      return sortDir === 'asc' ? av - bv : bv - av;
    }
    // date sort for order_date
    if (sortCol === 'order_date') {
      av = new Date(av); bv = new Date(bv);
      return sortDir === 'asc' ? av - bv : bv - av;
    }
    // string sort
    av = av.toString().toLowerCase(); bv = bv.toString().toLowerCase();
    if (av < bv) return sortDir === 'asc' ? -1 : 1;
    if (av > bv) return sortDir === 'asc' ?  1 : -1;
    return 0;
  });

  const onOrderPlaced = (newOrder) => {
    setOrders(prev => [newOrder, ...prev]);
    setShowPlaceOrder(false);
    notify(`Order #${newOrder.order_id} placed successfully!`);
  };

  const exportExcel = () => {
    const data = filtered.map(o => ({
      'Order Id': o.order_id,
      'Dealer': o.dealer_name || '',
      'Product': o.product_name,
      'Quantity': `${o.quantity} ${o.unit}`,
      'Delivery Location': o.delivery_location,
      'Order Date': o.order_date,
      'Status': o.order_status,
      'Vehicle No': o.dispatch ? o.dispatch.vehicle_no : '',
      'Driver Name': o.dispatch ? o.dispatch.driver_name : '',
      'Driver Phone': o.dispatch ? o.dispatch.driver_phone : '',
      'Dispatch Date': o.dispatch ? o.dispatch.dispatch_date : '',
      'Expected Delivery': o.dispatch ? o.dispatch.expected_delivery : '',
      'Actual Delivery': o.dispatch ? (o.dispatch.actual_delivery || '') : '',
      'Dispatch Status': o.dispatch ? o.dispatch.dispatch_status : '',
      'Remarks': o.remarks || '',
    }));
    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, IS_ADMIN ? 'All Orders' : 'My Orders');
    XLSX.writeFile(wb, IS_ADMIN ? 'All_Orders_Dispatch.xlsx' : 'My_Orders.xlsx');
  };

  return (
    <div>
      {toast.msg && (
        <div className={`alert alert-${toast.type} alert-dismissible mb-3`}>
          {toast.msg}
          <button className="btn-close" onClick={() => setToast({ msg: '' })}></button>
        </div>
      )}

      {/* Summary Cards */}
      <div className="row mb-2">
        <SummaryCard label="Total Orders"  value={counts.total}     color="primary" icon="📋" />
        <SummaryCard label="Pending"       value={counts.pending}   color="warning" icon="🕐" />
        <SummaryCard label="In Transit"    value={counts.inTransit} color="info"    icon="🚛" />
        <SummaryCard label="Delivered"     value={counts.delivered} color="success" icon="🏁" />
      </div>

      {/* Orders Table */}
      <div className="card shadow-sm">
        <div className="card-header bg-white d-flex align-items-center justify-content-between py-3">
          <h5 className="mb-0 fw-semibold">{IS_ADMIN ? '📊 All Orders & Dispatch' : '📋 My Orders'}</h5>
          <div className="d-flex gap-2">
            <button className="btn btn-outline-success btn-sm" onClick={exportExcel}>
              ⬇️ Download Excel
            </button>
            {!IS_ADMIN && (
              <button className="btn btn-primary btn-sm" onClick={() => setShowPlaceOrder(true)}>
                🛒 Place New Order
              </button>
            )}
          </div>
        </div>
        <div className="card-body">
          <div className="row mb-3 g-2">
            <div className="col-md-5">
              <input className="form-control" placeholder="Search by product, location, order ID…"
                value={search} onChange={e => setSearch(e.target.value)} />
            </div>
            <div className="col-md-4">
              <select className="form-select" value={statusFilter} onChange={e => setStatusFilter(e.target.value)}>
                <option value="ALL">All Statuses</option>
                {Object.entries(STATUS_CONFIG).map(([k, v]) =>
                  <option key={k} value={k}>{v.text}</option>
                )}
              </select>
            </div>
            <div className="col text-end text-muted small align-self-center">
              {sorted.length} order{sorted.length !== 1 ? 's' : ''}
            </div>
          </div>

          {loading ? (
            <div className="text-center py-5">
              <div className="spinner-border text-primary"></div>
              <p className="text-muted mt-2">Loading orders…</p>
            </div>
          ) : (
            <div className="table-responsive">
              <table className="table table-hover table-bordered align-middle mb-0">
                <thead className="table-light">
                  <tr>
                    <SortTh col="order_id" style={{ width: 90 }}>Order Id</SortTh>
                    {IS_ADMIN && <SortTh col="dealer_name">Dealer</SortTh>}
                    <SortTh col="product_name">Product</SortTh>
                    <SortTh col="quantity" style={{ width: 100 }}>Qty</SortTh>
                    <SortTh col="delivery_location">Delivery Location</SortTh>
                    <SortTh col="order_date" style={{ width: 110 }}>Order Date</SortTh>
                    <th style={{ width: 130, textAlign: 'center' }}>Status</th>
                    <th style={{ width: 120, textAlign: 'center' }}>Dispatch</th>
                    <th style={{ width: 180, textAlign: 'center' }}>Action</th>
                  </tr>
                </thead>
                <tbody>
                  {sorted.length === 0 ? (
                    <tr><td colSpan={IS_ADMIN ? 9 : 8} className="text-center text-muted py-4">No orders found</td></tr>
                  ) : sorted.map(o => (
                    <tr key={o.order_id}>
                      <td className="fw-semibold text-primary">#{o.order_id}</td>
                      {IS_ADMIN && <td className="text-muted small">{o.dealer_name || '—'}</td>}
                      <td>{o.product_name}</td>
                      <td>{o.quantity} {o.unit}</td>
                      <td>{o.delivery_location}</td>
                      <td>{o.order_date}</td>
                      <td className="text-center"><StatusBadge status={o.order_status} /></td>
                      <td className="text-center">
                        {o.dispatch ? (
                          <span className="text-success small fw-semibold">
                            🚛 {o.dispatch.vehicle_no}
                          </span>
                        ) : (
                          <span className="text-muted small">—</span>
                        )}
                      </td>
                      <td className="text-center">
                        <div className="d-flex justify-content-center gap-2 flex-wrap">
                          <button className="btn btn-outline-primary btn-sm"
                            onClick={() => setSelectedOrder(o)}>
                            View
                          </button>
                          {o.dispatch && o.dispatch.driver_phone && (
                            <a
                              className="btn btn-outline-success btn-sm"
                              href={`/tracking?driver=${encodeURIComponent(o.dispatch.driver_phone)}&order=${o.order_id}`}
                            >
                              Track
                            </a>
                          )}
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>

      {selectedOrder && <DispatchModal order={selectedOrder} onClose={() => setSelectedOrder(null)} />}
      {showPlaceOrder && <PlaceOrderModal onClose={() => setShowPlaceOrder(false)} onSaved={onOrderPlaced} />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<App />);
</script>
<%- include('../partials/footer') %>
