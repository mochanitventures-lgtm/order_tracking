<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="#">Master Data</a></li>
    <li class="breadcrumb-item active">Dealers</li>
  </ol>
</nav>
<div id="app-root"></div>

<script type="text/babel">
const { useState, useEffect } = React;
const EMPTY_DEALER = { dealer_name:'', dealer_company_name:'', dealer_code:'', dealer_phone:'', dealer_email:'', dealer_daily_limit:'', dealer_monthly_target:'', dealer_is_active_flag:true };
const EMPTY_PARTY  = { party_code:'', party_name:'', party_company_name:'', party_phone:'', party_email:'', party_address:'', party_is_active_flag:true, dealer_id:'' };

function Toast({msg,type,onClose}){
  if(!msg) return null;
  return <div className={`alert alert-${type} alert-dismissible`}>{msg}<button className="btn-close ms-2" onClick={onClose}></button></div>;
}

/* ── Party side-panel modal ─────────────────────────────────────── */
function PartyModal({dealer, onClose, notify}){
  const [parties,setParties]=useState([]);
  const [loading,setLoading]=useState(true);
  const [form,setForm]=useState(EMPTY_PARTY);
  const [editId,setEditId]=useState(null);
  const [saving,setSaving]=useState(false);
  const [showForm,setShowForm]=useState(false);

  const loadParties=async()=>{
    setLoading(true);
    try{
      const r=await fetch(`/api/party/by-dealer/${encodeURIComponent(dealer.dealer_id)}`);
      if(!r.ok) throw new Error(await r.text());
      setParties(await r.json());
    }catch(e){notify(e.message,'danger');}
    finally{setLoading(false);}
  };
  useEffect(()=>{loadParties();},[]);

  const openAdd=()=>{setForm({...EMPTY_PARTY,dealer_id:dealer.dealer_id});setEditId(null);setShowForm(true);};
  const openEdit=(p)=>{
    setForm({party_code:p.party_code||'',party_name:p.party_name||'',party_company_name:p.party_company_name||'',party_phone:p.party_phone||'',party_email:p.party_email||'',party_address:p.party_address||'',party_is_active_flag:p.party_is_active_flag});
    setEditId(p.party_id);setShowForm(true);
  };

  const save=async(e)=>{
    e.preventDefault();setSaving(true);
    try{
      const payload={...form,dealer_id:dealer.dealer_id};
      const res=await fetch(editId?`/api/party/${editId}`:'/api/party',{method:editId?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      const d=await res.json();if(!res.ok)throw new Error(d.error);
      notify(editId?'Party updated':'Party added');
      setShowForm(false);loadParties();
    }catch(e){notify(e.message,'danger');}
    finally{setSaving(false);}
  };

  return(
    <div className="modal d-block" tabIndex="-1" style={{background:'rgba(0,0,0,0.5)'}}>
      <div className="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div className="modal-content">
          <div className="modal-header">
            <div>
              <h5 className="modal-title mb-0">Parties for: <span className="text-primary">{dealer.dealer_name}</span></h5>
              <small className="text-muted">Dealer Code: {dealer.dealer_code}</small>
            </div>
            <div className="d-flex gap-2 align-items-center">
              {!showForm&&<button className="btn btn-primary btn-sm" onClick={openAdd}>+ Add Party</button>}
              <button type="button" className="btn-close" onClick={onClose}></button>
            </div>
          </div>
          <div className="modal-body">
            {/* Add / Edit form */}
            {showForm&&(
              <div className="card mb-3 border-primary">
                <div className="card-header bg-primary bg-opacity-10 fw-semibold py-2">
                  {editId?'Edit Party':'Add New Party'}
                  <button type="button" className="btn-close float-end" onClick={()=>setShowForm(false)}></button>
                </div>
                <div className="card-body">
                  <form onSubmit={save}>
                    <div className="row g-3">
                      <div className="col-md-4">
                        <label className="form-label fw-semibold">Party Code <span className="text-muted fw-normal small">(Optional)</span></label>
                        <input className="form-control form-control-sm" value={form.party_code} onChange={e=>setForm({...form,party_code:e.target.value})}/>
                      </div>
                      <div className="col-md-4">
                        <label className="form-label fw-semibold">Party Company Name <span className="text-danger">*</span></label>
                        <input className="form-control form-control-sm" value={form.party_company_name} onChange={e=>setForm({...form,party_company_name:e.target.value})} required/>
                      </div>
                      <div className="col-md-4">
                        <label className="form-label fw-semibold">Party Name <span className="text-muted fw-normal small">(Optional)</span></label>
                        <input className="form-control form-control-sm" value={form.party_name} onChange={e=>setForm({...form,party_name:e.target.value})}/>
                      </div>
                      <div className="col-md-4">
                        <label className="form-label fw-semibold">Phone <span className="text-muted fw-normal small">(Optional)</span></label>
                        <input className="form-control form-control-sm" value={form.party_phone} onChange={e=>setForm({...form,party_phone:e.target.value})}/>
                      </div>
                      <div className="col-md-4">
                        <label className="form-label fw-semibold">Email <span className="text-muted fw-normal small">(Optional)</span></label>
                        <input className="form-control form-control-sm" type="email" value={form.party_email} onChange={e=>setForm({...form,party_email:e.target.value})}/>
                      </div>
                      <div className="col-md-4">
                        <label className="form-label fw-semibold">Address</label>
                        <input className="form-control form-control-sm" value={form.party_address} onChange={e=>setForm({...form,party_address:e.target.value})}/>
                      </div>
                      <div className="col-12 d-flex align-items-center gap-3">
                        <div className="form-check form-switch">
                          <input className="form-check-input" type="checkbox" id="partyActiveInline" checked={form.party_is_active_flag} onChange={e=>setForm({...form,party_is_active_flag:e.target.checked})}/>
                          <label className="form-check-label" htmlFor="partyActiveInline">Active</label>
                        </div>
                        <button type="submit" className="btn btn-primary btn-sm" disabled={saving}>
                          {saving&&<span className="spinner-border spinner-border-sm me-1"></span>}
                          {editId?'Update Party':'Save Party'}
                        </button>
                        <button type="button" className="btn btn-secondary btn-sm" onClick={()=>setShowForm(false)}>Cancel</button>
                      </div>
                    </div>
                  </form>
                </div>
              </div>
            )}

            {/* Party list table */}
            {loading
              ?<div className="text-center py-4"><div className="spinner-border text-primary"></div></div>
              :parties.length===0
                ?<div className="text-center text-muted py-4">No parties linked to this dealer. Click <strong>+ Add Party</strong> to create one.</div>
                :<div className="table-responsive">
                  <table className="table table-sm table-hover table-bordered align-middle mb-0">
                    <thead className="table-light">
                      <tr>
                        <th>Party Code</th>
                        <th>Party Name</th>
                        <th>Party Company Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th className="text-center">Status</th>
                        <th className="text-center">Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {parties.map(p=><tr key={p.party_id}>
                        <td className="fw-semibold">{p.party_code||<span className="text-muted">—</span>}</td>
                        <td className="fw-semibold">{p.party_name}</td>
                        <td>{p.party_company_name||<span className="text-muted">—</span>}</td>
                        <td>{p.party_phone||<span className="text-muted">—</span>}</td>
                        <td>{p.party_email||<span className="text-muted">—</span>}</td>
                        <td>{p.party_address||<span className="text-muted">—</span>}</td>
                        <td className="text-center">
                          {p.party_is_active_flag?<span className="badge bg-success">Active</span>:<span className="badge bg-secondary">Inactive</span>}
                        </td>
                        <td className="text-center">
                          <button className="btn btn-outline-primary btn-sm" onClick={()=>openEdit(p)}>Edit</button>
                        </td>
                      </tr>)}
                    </tbody>
                  </table>
                </div>
            }
          </div>
          <div className="modal-footer">
            <button className="btn btn-secondary btn-sm" onClick={onClose}>Close</button>
          </div>
        </div>
      </div>
    </div>
  );
}

/* ── Main App ────────────────────────────────────────────────────── */
function App(){
  const [rows,setRows]=useState([]); 
  const [loading,setLoading]=useState(true); const [search,setSearch]=useState('');
  const [showModal,setShowModal]=useState(false); const [form,setForm]=useState(EMPTY_DEALER);
  const [editId,setEditId]=useState(null); const [saving,setSaving]=useState(false);
  const [toast,setToast]=useState({msg:'',type:'success'});
  const [sortCol,setSortCol]=useState('dealer_id'); const [sortAsc,setSortAsc]=useState(true);
  const [bulkUploading,setBulkUploading]=useState(false);
  const [partyDealer,setPartyDealer]=useState(null);
  const fileRef=React.useRef(null);

  const notify=(msg,type='success')=>{setToast({msg,type});setTimeout(()=>setToast({msg:''}),4000);};
  const load=async()=>{setLoading(true);try{
    const dr=await fetch('/api/dealers');
    if(!dr.ok)throw new Error(await dr.text());
    setRows(await dr.json());
  }catch(e){notify(e.message,'danger');}finally{setLoading(false);}};
  useEffect(()=>{load();},[]);

  const openAdd=()=>{setForm(EMPTY_DEALER);setEditId(null);setShowModal(true);};
  const exportExcel=()=>{
    const data=filtered.map(r=>({'ID':r.dealer_id,'Dealer Name':r.dealer_name,'Dealer Company Name':r.dealer_company_name||'','Dealer Code':r.dealer_code||'','Phone':r.dealer_phone||'','Address':r.dealer_address||'','Daily Limit':r.dealer_daily_limit||0,'Monthly Target':r.dealer_monthly_target||0,'Active':r.dealer_is_active_flag?'Yes':'No','Created At':r.created_at?new Date(r.created_at).toLocaleDateString():''}) );
    const ws=XLSX.utils.json_to_sheet(data); const wb=XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb,ws,'Dealers'); XLSX.writeFile(wb,'Dealers.xlsx');
  };
  const bulkUpload=async(e)=>{
    const file=e.target.files[0]; if(!file) return;
    e.target.value='';
    setBulkUploading(true);
    try{
      const ab=await file.arrayBuffer();
      const wb=XLSX.read(ab,{type:'array'});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const rowsData=XLSX.utils.sheet_to_json(ws);
      const updates=rowsData
        .map(r=>{const k=Object.fromEntries(Object.entries(r).map(([h,v])=>[h.toLowerCase().trim(),v]));return{dealer_id:k['id'],dealer_daily_limit:parseFloat(k['daily limit']??0)||0,dealer_monthly_target:parseFloat(k['monthly target']??0)||0};})
        .filter(u=>u.dealer_id);
      if(!updates.length) throw new Error('No valid rows found. File must have columns: ID, Daily Limit, Monthly Target.');
      const res=await fetch('/api/dealers/bulk-limits',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({updates})});
      const d=await res.json(); if(!res.ok) throw new Error(d.error);
      notify(`${d.updated} dealer(s) limits updated successfully`);
      setTimeout(()=>window.location.reload(),800);
    }catch(e){notify(e.message,'danger');}finally{setBulkUploading(false);};
  };
  const openEdit=(r)=>{setForm({dealer_name:r.dealer_name,dealer_company_name:r.dealer_company_name||'',dealer_code:r.dealer_code||'',dealer_phone:r.dealer_phone||'',dealer_email:r.dealer_email||'',dealer_daily_limit:r.dealer_daily_limit||'',dealer_monthly_target:r.dealer_monthly_target||'',dealer_is_active_flag:r.dealer_is_active_flag});setEditId(r.dealer_id);setShowModal(true);};

  const save=async(e)=>{e.preventDefault();setSaving(true);
    try{const res=await fetch(editId?`/api/dealers/${editId}`:'/api/dealers',{method:editId?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(form)});
    const d=await res.json();if(!res.ok)throw new Error(d.error);notify(editId?'Updated':'Added');setShowModal(false);setTimeout(()=>window.location.reload(),800);}
    catch(e){notify(e.message,'danger');}finally{setSaving(false);}};

  const sort=(col)=>{if(sortCol===col)setSortAsc(!sortAsc);else{setSortCol(col);setSortAsc(true);}};
  const SI=({col})=>sortCol===col?<span className="ms-1">{sortAsc?'↑':'↓'}</span>:<span className="text-muted ms-1">⇅</span>;

  const filtered=[...rows].filter(r=>(r.dealer_name+' '+(r.dealer_company_name||'')+' '+(r.dealer_code||'')).toLowerCase().includes(search.toLowerCase()))
    .sort((a,b)=>{let va=a[sortCol],vb=b[sortCol];if(typeof va==='string')va=va.toLowerCase();if(typeof vb==='string')vb=vb.toLowerCase();return sortAsc?(va<vb?-1:va>vb?1:0):(va>vb?-1:va<vb?1:0);});

  return(<div>
    <Toast msg={toast.msg} type={toast.type} onClose={()=>setToast({msg:''})}/>
    <div className="card shadow-sm">
      <div className="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <h5 className="mb-0 fw-semibold">Dealers</h5>
        <div className="d-flex gap-2">
          <button className="btn btn-outline-success btn-sm" onClick={exportExcel}>⬇️ Download Excel</button>
          <input ref={fileRef} type="file" accept=".xlsx,.xls" style={{display:'none'}} onChange={bulkUpload}/>
          <button
            className="btn btn-outline-warning btn-sm"
            title="It will update only Daily and Monthly limit"
            onClick={()=>fileRef.current.click()}
            disabled={bulkUploading}>
            {bulkUploading?<span className="spinner-border spinner-border-sm me-1"></span>:null}📤 Bulk Upload
          </button>
          <button className="btn btn-primary btn-sm" onClick={openAdd}>+ Add Dealer</button>
        </div>
      </div>
      <div className="card-body">
        <div className="row mb-3">
          <div className="col-md-4"><input className="form-control" placeholder="Search…" value={search} onChange={e=>setSearch(e.target.value)}/></div>
          <div className="col text-end text-muted small align-self-center">{filtered.length} record{filtered.length!==1?'s':''}</div>
        </div>
        {loading?<div className="text-center py-5"><div className="spinner-border text-primary"></div></div>:(
        <div className="table-responsive">
          <table className="table table-hover table-bordered align-middle mb-0">
            <thead className="table-light"><tr>
              <th style={{cursor:'pointer'}} onClick={()=>sort('dealer_code')}>Dealer Code<SI col="dealer_code"/></th>
              <th style={{cursor:'pointer'}} onClick={()=>sort('dealer_name')}>Dealer Name<SI col="dealer_name"/></th>
              <th style={{cursor:'pointer'}} onClick={()=>sort('dealer_company_name')}>Dealer Company Name<SI col="dealer_company_name"/></th>
              <th style={{cursor:'pointer',textAlign:'right'}} onClick={()=>sort('dealer_daily_limit')}>Daily Limit<SI col="dealer_daily_limit"/></th>
              <th style={{cursor:'pointer',textAlign:'right'}} onClick={()=>sort('dealer_monthly_target')}>Monthly Target<SI col="dealer_monthly_target"/></th>
              <th>Phone</th>
              <th style={{width:'90px',textAlign:'center'}}>Status</th>
              <th style={{width:'110px',textAlign:'center'}}>Action</th>
              <th style={{width:'100px',textAlign:'center'}}>Party</th>
            </tr></thead>
            <tbody>{filtered.length===0?<tr><td colSpan="9" className="text-center text-muted py-4">No dealers found</td></tr>:
              filtered.map(r=><tr key={r.dealer_id}>
                <td className="fw-semibold">{r.dealer_code||<span className="text-muted">—</span>}</td>
                <td className="fw-semibold">{r.dealer_name}</td>
                <td>{r.dealer_company_name||<span className="text-muted">—</span>}</td>
                <td className="text-end">{r.dealer_daily_limit!=null?Number(r.dealer_daily_limit).toLocaleString():<span className="text-muted">—</span>}</td>
                <td className="text-end">{r.dealer_monthly_target!=null?Number(r.dealer_monthly_target).toLocaleString():<span className="text-muted">—</span>}</td>
                <td>{r.dealer_phone||<span className="text-muted">—</span>}</td>
                <td className="text-center">{r.dealer_is_active_flag?<span className="badge bg-success">Active</span>:<span className="badge bg-secondary">Inactive</span>}</td>
                <td className="text-center"><button className="btn btn-outline-primary btn-sm" onClick={()=>openEdit(r)}>Edit</button></td>
                <td className="text-center">
                  <button className="btn btn-outline-secondary btn-sm" onClick={()=>setPartyDealer(r)} title="View / manage parties for this dealer">
                    🤝 View
                  </button>
                </td>
              </tr>)
            }</tbody>
          </table>
        </div>)}
      </div>
    </div>

    {/* Dealer add/edit modal */}
    {showModal&&<div className="modal d-block" tabIndex="-1" style={{background:'rgba(0,0,0,0.45)'}}>
      <div className="modal-dialog modal-dialog-centered modal-lg"><div className="modal-content">
        <form onSubmit={save}>
          <div className="modal-header"><h5 className="modal-title">{editId?'Edit':'Add'} Dealer</h5><button type="button" className="btn-close" onClick={()=>setShowModal(false)}></button></div>
          <div className="modal-body">
            <div className="row g-3">
              <div className="col-12"><label className="form-label fw-semibold">Dealer Code <span className="text-danger">*</span></label>
                <input className="form-control" value={form.dealer_code} onChange={e=>setForm({...form,dealer_code:e.target.value})} required/></div>
              <div className="col-md-6"><label className="form-label fw-semibold">Dealer Name <span className="text-danger">*</span></label>
                <input className="form-control" value={form.dealer_name} onChange={e=>setForm({...form,dealer_name:e.target.value})} required/></div>
              <div className="col-md-6"><label className="form-label fw-semibold">Dealer Company Name <span className="text-danger">*</span></label>
                <input className="form-control" value={form.dealer_company_name} onChange={e=>setForm({...form,dealer_company_name:e.target.value})} required/></div>
              <div className="col-md-6"><label className="form-label fw-semibold">Phone <span className="text-muted fw-normal small">(Optional)</span></label>
                <input className="form-control" value={form.dealer_phone} onChange={e=>setForm({...form,dealer_phone:e.target.value})}/></div>
              <div className="col-md-6"><label className="form-label fw-semibold">Email <span className="text-muted fw-normal small">(Optional)</span></label>
                <input className="form-control" type="email" value={form.dealer_email} onChange={e=>setForm({...form,dealer_email:e.target.value})}/></div>
              <div className="col-md-6"><label className="form-label fw-semibold">Daily Limit <span className="text-danger">*</span></label>
                <input className="form-control" type="number" min="0" step="0.01" placeholder="e.g. 100" value={form.dealer_daily_limit} onChange={e=>setForm({...form,dealer_daily_limit:e.target.value})} required/></div>
              <div className="col-md-6"><label className="form-label fw-semibold">Monthly Target <span className="text-danger">*</span></label>
                <input className="form-control" type="number" min="0" step="0.01" placeholder="e.g. 2000" value={form.dealer_monthly_target} onChange={e=>setForm({...form,dealer_monthly_target:e.target.value})} required/></div>
              <div className="col-md-6 d-flex align-items-end"><div className="form-check form-switch">
                <input className="form-check-input" type="checkbox" id="dealActive" checked={form.dealer_is_active_flag} onChange={e=>setForm({...form,dealer_is_active_flag:e.target.checked})}/>
                <label className="form-check-label" htmlFor="dealActive">Active</label>
              </div></div>
            </div>
          </div>
          <div className="modal-footer">
            <button type="button" className="btn btn-secondary" onClick={()=>setShowModal(false)}>Cancel</button>
            <button type="submit" className="btn btn-primary" disabled={saving}>{saving&&<span className="spinner-border spinner-border-sm me-1"></span>}{editId?'Update':'Add Dealer'}</button>
          </div>
        </form>
      </div></div>
    </div>}

    {/* Party modal */}
    {partyDealer&&<PartyModal dealer={partyDealer} onClose={()=>setPartyDealer(null)} notify={notify}/>}
  </div>);
}
ReactDOM.createRoot(document.getElementById('app-root')).render(<App/>);
</script>
<%- include('../partials/footer') %>
