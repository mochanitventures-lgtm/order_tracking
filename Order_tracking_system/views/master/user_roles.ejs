<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="#">Master Data</a></li>
    <li class="breadcrumb-item active">User Roles</li>
  </ol>
</nav>
<div id="app-root"></div>

<script type="text/babel">
const { useState, useEffect } = React;
const EMPTY = { role_name:'', role_desc:'' };

function Toast({msg,type,onClose}){
  if(!msg) return null;
  return <div className={`alert alert-${type} alert-dismissible`}>{msg}<button className="btn-close ms-2" onClick={onClose}></button></div>;
}

function App(){
  const [rows,setRows]=useState([]);
  const [loading,setLoading]=useState(true); const [search,setSearch]=useState('');
  const [showModal,setShowModal]=useState(false); const [form,setForm]=useState(EMPTY);
  const [editId,setEditId]=useState(null); const [saving,setSaving]=useState(false);
  const [toast,setToast]=useState({msg:'',type:'success'});
  const [sortCol,setSortCol]=useState('role_id'); const [sortAsc,setSortAsc]=useState(true);

  const notify=(msg,type='success')=>{setToast({msg,type});setTimeout(()=>setToast({msg:''}),4000);};
  const load=async()=>{setLoading(true);try{
    const r=await fetch('/api/user-roles');
    if(!r.ok)throw new Error(await r.text());
    setRows(await r.json());
  }catch(e){notify(e.message,'danger');}finally{setLoading(false);}};
  useEffect(()=>{load();},[]);

  const openAdd=()=>{setForm(EMPTY);setEditId(null);setShowModal(true);};
  const exportExcel=()=>{
    const data=filtered.map(r=>({'ID':r.role_id,'Role Name':r.role_name,'Description':r.role_desc||'','Created At':r.created_at?new Date(r.created_at).toLocaleDateString():''}) );
    const ws=XLSX.utils.json_to_sheet(data); const wb=XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb,ws,'UserRoles'); XLSX.writeFile(wb,'UserRoles.xlsx');
  };
  const openEdit=(r)=>{setForm({role_name:r.role_name,role_desc:r.role_desc||''});setEditId(r.role_id);setShowModal(true);};

  const save=async(e)=>{e.preventDefault();setSaving(true);
    try{const res=await fetch(editId?`/api/user-roles/${editId}`:'/api/user-roles',{method:editId?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(form)});
    const d=await res.json();if(!res.ok)throw new Error(d.error);notify(editId?'Role updated':'Role created');setShowModal(false);load();}
    catch(e){notify(e.message,'danger');}finally{setSaving(false);}};

  const sort=(col)=>{if(sortCol===col)setSortAsc(!sortAsc);else{setSortCol(col);setSortAsc(true);}};
  const SI=({col})=>sortCol===col?<span className="ms-1">{sortAsc?'↑':'↓'}</span>:<span className="text-muted ms-1">⇅</span>;
  const fmt=(d)=>d?new Date(d).toLocaleDateString():'—';

  const filtered=[...rows].filter(r=>(r.role_name+' '+(r.role_desc||'')).toLowerCase().includes(search.toLowerCase()))
    .sort((a,b)=>{let va=a[sortCol],vb=b[sortCol];if(typeof va==='string')va=va.toLowerCase();if(typeof vb==='string')vb=vb.toLowerCase();return sortAsc?(va<vb?-1:va>vb?1:0):(va>vb?-1:va<vb?1:0);});

  return(<div>
    <Toast msg={toast.msg} type={toast.type} onClose={()=>setToast({msg:''})}/>
    <div className="card shadow-sm">
      <div className="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <h5 className="mb-0 fw-semibold">User Roles</h5>
        <div className="d-flex gap-2">
          <button className="btn btn-outline-success btn-sm" onClick={exportExcel}>⬇️ Download Excel</button>
          <button className="btn btn-primary btn-sm" onClick={openAdd}>+ Add Role</button>
        </div>
      </div>
      <div className="card-body">
        <div className="row mb-3">
          <div className="col-md-4"><input className="form-control" placeholder="Search…" value={search} onChange={e=>setSearch(e.target.value)}/></div>
          <div className="col text-end text-muted small align-self-center">{filtered.length} record{filtered.length!==1?'s':''}</div>
        </div>
        {loading?<div className="text-center py-5"><div className="spinner-border text-primary"></div></div>:(
        <div className="table-responsive">
          <table className="table table-hover table-bordered align-middle mb-0">
            <thead className="table-light"><tr>
              <th style={{cursor:'pointer',width:'60px'}} onClick={()=>sort('role_id')}>ID<SI col="role_id"/></th>
              <th style={{cursor:'pointer'}} onClick={()=>sort('role_name')}>Role Name<SI col="role_name"/></th>
              <th>Description</th>
              <th style={{cursor:'pointer',width:'130px'}} onClick={()=>sort('updated_at')}>Updated<SI col="updated_at"/></th>
              <th style={{width:'90px',textAlign:'center'}}>Action</th>
            </tr></thead>
            <tbody>{filtered.length===0?<tr><td colSpan="5" className="text-center text-muted py-4">No roles found</td></tr>:
              filtered.map(r=><tr key={r.role_id}>
                <td>{r.role_id}</td>
                <td><span className="badge bg-primary">{r.role_name}</span></td>
                <td>{r.role_desc||<span className="text-muted">—</span>}</td>
                <td>{fmt(r.updated_at)}</td>
                <td className="text-center"><button className="btn btn-outline-primary btn-sm" onClick={()=>openEdit(r)}>Edit</button></td>
              </tr>)
            }</tbody>
          </table>
        </div>)}
      </div>
    </div>
    {showModal&&<div className="modal d-block" tabIndex="-1" style={{background:'rgba(0,0,0,0.45)'}}>
      <div className="modal-dialog modal-dialog-centered"><div className="modal-content">
        <form onSubmit={save}>
          <div className="modal-header"><h5 className="modal-title">{editId?'Edit':'Add'} Role</h5><button type="button" className="btn-close" onClick={()=>setShowModal(false)}></button></div>
          <div className="modal-body">
            <div className="row g-3">
              <div className="col-12"><label className="form-label fw-semibold">Role Name <span className="text-danger">*</span></label>
                <input className="form-control text-uppercase" value={form.role_name} onChange={e=>setForm({...form,role_name:e.target.value.toUpperCase()})} required placeholder="e.g. MANAGER" disabled={!!editId}/></div>
              <div className="col-12"><label className="form-label fw-semibold">Description</label>
                <textarea className="form-control" rows="3" value={form.role_desc} onChange={e=>setForm({...form,role_desc:e.target.value})} placeholder="Role description…"/></div>
            </div>
          </div>
          <div className="modal-footer">
            <button type="button" className="btn btn-secondary" onClick={()=>setShowModal(false)}>Cancel</button>
            <button type="submit" className="btn btn-primary" disabled={saving}>{saving&&<span className="spinner-border spinner-border-sm me-1"></span>}{editId?'Update':'Add Role'}</button>
          </div>
        </form>
      </div></div>
    </div>}
  </div>);
}
ReactDOM.createRoot(document.getElementById('app-root')).render(<App/>);
</script>
<%- include('../partials/footer') %>
