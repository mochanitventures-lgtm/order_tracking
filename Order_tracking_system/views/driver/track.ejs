<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"/>
  <title>Driver Live Tracking — ODTS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f0f4f8; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
    .pill-card { border-radius: 16px; border: none; }
    #statusDot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; vertical-align: middle; }
    .stat-box { background: #fff; border-radius: 12px; padding: 12px 10px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .stat-val { font-size: 1.4rem; font-weight: 700; line-height: 1; }
    .stat-lbl { font-size: 0.7rem; color: #6c757d; text-transform: uppercase; margin-top: 2px; }
    #mapSmall { width: 100%; height: 200px; border-radius: 14px; overflow: hidden; position: relative; background: #dce6f0; }
    #mapSmall img, #mapIframe { width: 100%; height: 100%; border: 0; border-radius: 14px; }
    .btn-track-start { font-size: 1.1rem; padding: 14px; border-radius: 14px; font-weight: 700; }
    .pulse { animation: pulse 1.4s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .header-bar { background: #0d6efd; color: #fff; padding: 14px 16px; border-radius: 0 0 20px 20px; margin-bottom: 16px; }
  </style>
</head>
<body>

<div class="header-bar d-flex align-items-center gap-3">
  <div style="font-size:1.8rem">🚛</div>
  <div>
    <div class="fw-bold fs-5 mb-0">ODTS Driver Tracker</div>
    <div style="font-size:0.8rem;opacity:0.8;">Order Dispatch Tracking System</div>
  </div>
</div>

<div class="container-fluid px-3 pb-4" style="max-width: 480px; margin: auto;">

  <!-- Setup Section (shown if no phone pre-filled) -->
  <div id="setupSection">
    <div class="card pill-card shadow-sm mb-3">
      <div class="card-body">
        <h6 class="fw-bold mb-3">Your Details</h6>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Mobile Number <span class="text-danger">*</span></label>
          <input id="phoneInput" class="form-control" type="tel" placeholder="Enter your mobile number"
                 value="<%= defaultPhone %>" />
        </div>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Order ID</label>
          <input id="orderInput" class="form-control" placeholder="e.g. 1002" value="<%= defaultOrder %>"/>
        </div>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Vehicle Number</label>
          <input id="vehicleInput" class="form-control" placeholder="e.g. MH-12-AB-1234" value="<%= defaultVehicle %>"/>
        </div>
      </div>
    </div>
  </div>

  <!-- Status Card -->
  <div class="card pill-card shadow-sm mb-3">
    <div class="card-body">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <span id="statusDot" style="background:#adb5bd;"></span>
          <span id="statusText" class="ms-2 fw-semibold text-muted">Not tracking</span>
        </div>
        <span id="updateBadge" class="badge bg-secondary d-none">Waiting…</span>
      </div>
      <button id="toggleBtn" class="btn btn-primary btn-track-start w-100">
        🚀 Start Sharing Location
      </button>
      <div id="errorAlert" class="alert alert-danger mt-3 mb-0 d-none small"></div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="row g-2 mb-3" id="statsGrid" style="opacity:0.4;pointer-events:none;">
    <div class="col-4">
      <div class="stat-box">
        <div class="stat-val" id="statLat">—</div>
        <div class="stat-lbl">Latitude</div>
      </div>
    </div>
    <div class="col-4">
      <div class="stat-box">
        <div class="stat-val" id="statLng">—</div>
        <div class="stat-lbl">Longitude</div>
      </div>
    </div>
    <div class="col-4">
      <div class="stat-box">
        <div class="stat-val" id="statAcc">—</div>
        <div class="stat-lbl">Accuracy</div>
      </div>
    </div>
    <div class="col-4">
      <div class="stat-box">
        <div class="stat-val" id="statSpd">—</div>
        <div class="stat-lbl">Speed</div>
      </div>
    </div>
    <div class="col-4">
      <div class="stat-box">
        <div class="stat-val" id="statHdg">—</div>
        <div class="stat-lbl">Heading</div>
      </div>
    </div>
    <div class="col-4">
      <div class="stat-box">
        <div class="stat-val" id="statPts">0</div>
        <div class="stat-lbl">Updates</div>
      </div>
    </div>
  </div>

  <!-- Mini Map -->
  <div class="card pill-card shadow-sm mb-3" id="mapCard" style="opacity:0.4;">
    <div class="card-body p-2">
      <div id="mapSmall">
        <div id="mapPlaceholder" class="d-flex align-items-center justify-content-center h-100 text-muted small">
          📍 Map will appear once tracking starts
        </div>
        <iframe id="mapIframe" src="about:blank" class="d-none" allowfullscreen></iframe>
      </div>
    </div>
  </div>

  <!-- Info footer -->
  <p class="text-center text-muted" style="font-size: 0.72rem;">
    Your location is shared only while tracking is active.<br>
    Keep this browser tab open while driving.
  </p>
</div>

<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>
<script>
  const toggleBtn = document.getElementById('toggleBtn');
  const statusDot = document.getElementById('statusDot');
  const statusText = document.getElementById('statusText');
  const updateBadge = document.getElementById('updateBadge');
  const errorAlert = document.getElementById('errorAlert');
  const statsGrid = document.getElementById('statsGrid');
  const mapCard = document.getElementById('mapCard');
  const mapIframe = document.getElementById('mapIframe');
  const mapPlaceholder = document.getElementById('mapPlaceholder');

  let watching = false;
  let watchId = null;
  let updateCount = 0;
  let db = null;
  let currentPhone = null;
  let trackingPath = 'driver_locations';

  function showError(msg) {
    errorAlert.textContent = msg;
    errorAlert.classList.remove('d-none');
  }
  function clearError() { errorAlert.classList.add('d-none'); }

  function setStatus(active) {
    watching = active;
    statusDot.style.background = active ? '#198754' : '#adb5bd';
    if (active) statusDot.classList.add('pulse');
    else statusDot.classList.remove('pulse');
    statusText.textContent = active ? `Sharing — ${currentPhone}` : 'Not tracking';
    statusText.className = `ms-2 fw-semibold ${active ? 'text-success' : 'text-muted'}`;
    toggleBtn.className = `btn ${active ? 'btn-danger' : 'btn-primary'} btn-track-start w-100`;
    toggleBtn.textContent = active ? '⏹ Stop Sharing Location' : '🚀 Start Sharing Location';
    statsGrid.style.opacity = active ? '1' : '0.4';
    statsGrid.style.pointerEvents = active ? 'auto' : 'none';
    mapCard.style.opacity = active ? '1' : '0.4';
  }

  function updateMap(lat, lng) {
    mapPlaceholder.classList.add('d-none');
    mapIframe.classList.remove('d-none');
    mapIframe.src = `https://maps.google.com/maps?q=${lat},${lng}&z=15&output=embed&t=k`;
  }

  function pushToFirebase(position, phone) {
    if (!db || !phone) return;
    const { latitude: lat, longitude: lng, accuracy, speed, heading, altitude } = position.coords;
    const payload = {
      lat: parseFloat(lat.toFixed(6)),
      lng: parseFloat(lng.toFixed(6)),
      accuracy: accuracy ? Math.round(accuracy) : null,
      speed: speed ? Math.round(speed * 3.6) : null,   // m/s → km/h
      heading: heading ? Math.round(heading) : null,
      altitude: altitude ? Math.round(altitude) : null,
      status: 'IN_TRANSIT',
      timestamp: Date.now(),
      order_id: document.getElementById('orderInput').value.trim() || null,
      vehicle_no: document.getElementById('vehicleInput').value.trim() || null
    };
    const pathKey = `${trackingPath}/${phone}`;
    db.ref(pathKey).set(payload);

    updateCount++;
    document.getElementById('statLat').textContent = lat.toFixed(5);
    document.getElementById('statLng').textContent = lng.toFixed(5);
    document.getElementById('statAcc').textContent = accuracy ? `${Math.round(accuracy)}m` : '—';
    document.getElementById('statSpd').textContent = speed ? `${Math.round(speed * 3.6)}km/h` : '—';
    document.getElementById('statHdg').textContent = heading ? `${Math.round(heading)}°` : '—';
    document.getElementById('statPts').textContent = updateCount;

    updateBadge.textContent = `📡 ${new Date().toLocaleTimeString()}`;
    updateBadge.className = 'badge bg-success';
    updateBadge.classList.remove('d-none');

    updateMap(lat, lng);
  }

  async function fetchConfig() {
    const res = await fetch('/api/tracking/config');
    if (!res.ok) throw new Error('Failed to load Firebase config');
    return res.json();
  }

  async function startTracking() {
    clearError();
    const phone = document.getElementById('phoneInput').value.trim();
    if (!phone) { showError('Please enter your mobile number.'); return; }
    if (!navigator.geolocation) { showError('Geolocation is not supported by this browser.'); return; }

    toggleBtn.disabled = true;
    toggleBtn.textContent = '⏳ Initializing…';

    try {
      if (!db) {
        const cfg = await fetchConfig();
        if (!cfg.firebase || !cfg.firebase.databaseURL) {
          showError('Firebase is not configured on the server yet.');
          toggleBtn.disabled = false; toggleBtn.textContent = '🚀 Start Sharing Location';
          return;
        }
        if (!firebase.apps.length) firebase.initializeApp(cfg.firebase);
        db = firebase.database();
        trackingPath = cfg.trackingPathPrefix || 'driver_locations';
      }

      currentPhone = phone;
      watchId = navigator.geolocation.watchPosition(
        (pos) => { pushToFirebase(pos, currentPhone); },
        (err) => {
          showError(`GPS error: ${err.message}. Ensure location permission is granted.`);
          stopTracking();
        },
        { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
      );

      setStatus(true);
    } catch (e) {
      showError(e.message);
      toggleBtn.textContent = '🚀 Start Sharing Location';
    } finally {
      toggleBtn.disabled = false;
    }
  }

  function stopTracking() {
    if (watchId !== null) { navigator.geolocation.clearWatch(watchId); watchId = null; }
    // Write offline status to Firebase
    if (db && currentPhone) {
      db.ref(`${trackingPath}/${currentPhone}/status`).set('STOPPED');
    }
    updateCount = 0;
    currentPhone = null;
    setStatus(false);
    updateBadge.classList.add('d-none');
    mapIframe.src = 'about:blank';
    mapIframe.classList.add('d-none');
    mapPlaceholder.classList.remove('d-none');
  }

  toggleBtn.addEventListener('click', () => {
    if (watching) stopTracking();
    else startTracking();
  });

  // Auto-start if phone is pre-filled in URL
  window.addEventListener('load', () => {
    const phone = document.getElementById('phoneInput').value.trim();
    if (phone) {
      document.getElementById('setupSection').style.display = 'none';
      startTracking();
    }
  });

  // Stop publishing when tab is hidden/closed
  document.addEventListener('visibilitychange', () => {
    if (document.hidden && watching && db && currentPhone) {
      db.ref(`${trackingPath}/${currentPhone}/status`).set('BACKGROUND');
    }
    if (!document.hidden && watching && db && currentPhone) {
      db.ref(`${trackingPath}/${currentPhone}/status`).set('IN_TRANSIT');
    }
  });

  window.addEventListener('beforeunload', () => {
    if (watching && db && currentPhone) {
      db.ref(`${trackingPath}/${currentPhone}/status`).set('OFFLINE');
    }
  });
</script>
</body>
</html>
