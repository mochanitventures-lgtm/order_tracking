<%- include('../partials/header') %>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Live Tracking</li>
  </ol>
</nav>

<div class="row g-3 mb-3">
  <div class="col-lg-4">
    <div class="card shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Track by Driver Mobile</div>
      <div class="card-body">
        <form id="trackForm" class="d-grid gap-3">
          <div>
            <label class="form-label fw-semibold">Driver Mobile Number <span class="text-danger">*</span></label>
            <input id="driverPhone" class="form-control" placeholder="e.g. 9123456780" value="<%= defaultDriverPhone %>" required />
          </div>
          <div>
            <label class="form-label fw-semibold">Order ID (optional)</label>
            <input id="orderId" class="form-control" placeholder="e.g. 1002" value="<%= defaultOrderId %>" />
          </div>
          <button class="btn btn-primary" type="submit">Start Live Tracking</button>
        </form>

        <div id="configAlert" class="alert alert-warning mt-3 d-none"></div>
        <div id="trackStatus" class="alert alert-info mt-3 mb-0 d-none"></div>

        <hr class="my-3"/>
        <h6 class="fw-semibold mb-2">📤 Send Tracking Link to Driver</h6>
        <p class="text-muted small mb-2">Generate a link the driver opens on their phone to start sharing GPS.</p>
        <div class="input-group input-group-sm mb-2">
          <span class="input-group-text">Mobile</span>
          <input id="shareMobile" class="form-control" placeholder="Driver mobile number"/>
        </div>
        <div class="input-group input-group-sm mb-2">
          <span class="input-group-text">Order</span>
          <input id="shareOrder" class="form-control" placeholder="Order ID (optional)"/>
        </div>
        <div class="input-group input-group-sm mb-3">
          <span class="input-group-text">Vehicle</span>
          <input id="shareVehicle" class="form-control" placeholder="Vehicle no. (optional)"/>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-primary btn-sm" onclick="generateDriverLink()">
            🔗 Copy Link
          </button>
          <a id="openDriverLink" href="#" target="_blank" class="btn btn-outline-secondary btn-sm d-none">Open</a>
        </div>
        <div id="linkCopied" class="alert alert-success mt-2 py-2 d-none small">Driver link copied to clipboard!</div>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow-sm h-100">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Google Maps – Real-time Vehicle Location</span>
        <span id="lastUpdate" class="small text-muted">Last update: —</span>
      </div>
      <div class="card-body p-0">
        <div id="map" style="height: 430px; width: 100%; background: #f8f9fa;"></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Related Order / Dispatch Details</div>
      <div class="card-body" id="orderInfo">
        <p class="text-muted mb-0">Enter driver mobile number and click Start Live Tracking.</p>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Live Telemetry</div>
      <div class="card-body">
        <div class="row g-2" id="telemetryCards">
          <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Latitude</small><div id="latVal" class="fw-semibold">—</div></div></div>
          <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Longitude</small><div id="lngVal" class="fw-semibold">—</div></div></div>
          <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Speed</small><div id="speedVal" class="fw-semibold">—</div></div></div>
          <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Heading</small><div id="headingVal" class="fw-semibold">—</div></div></div>
          <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Accuracy</small><div id="accVal" class="fw-semibold">—</div></div></div>
          <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Driver Status</small><div id="statusVal" class="fw-semibold">—</div></div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>
<script>
  let map;
  let marker;
  let pathPolyline;
  let db;
  let unsubRef = null;
  let mapLoaded = false;
  let trackingConfig = null;

  const mapEl = document.getElementById('map');
  const trackForm = document.getElementById('trackForm');
  const trackStatus = document.getElementById('trackStatus');
  const configAlert = document.getElementById('configAlert');

  function showStatus(message, type = 'info') {
    trackStatus.className = `alert alert-${type} mt-3 mb-0`;
    trackStatus.textContent = message;
    trackStatus.classList.remove('d-none');
  }

  function showConfigError(message) {
    configAlert.textContent = message;
    configAlert.classList.remove('d-none');
  }

  function setTelemetry(data) {
    document.getElementById('latVal').textContent = data.lat ?? '—';
    document.getElementById('lngVal').textContent = data.lng ?? '—';
    document.getElementById('speedVal').textContent = data.speed ? `${data.speed} km/h` : '—';
    document.getElementById('headingVal').textContent = data.heading ? `${data.heading}°` : '—';
    document.getElementById('accVal').textContent = data.accuracy ? `${data.accuracy} m` : '—';
    document.getElementById('statusVal').textContent = data.status || '—';
  }

  function setOrderInfo(order) {
    const el = document.getElementById('orderInfo');
    if (!order) {
      el.innerHTML = '<p class="text-muted mb-0">No matching order found for this driver mobile number.</p>';
      return;
    }
    const dispatch = order.dispatch || {};
    el.innerHTML = `
      <div class="row g-2">
        <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Order ID</small><div class="fw-semibold">#${order.order_id}</div></div></div>
        <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Order Status</small><div class="fw-semibold">${order.order_status}</div></div></div>
        <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Product</small><div class="fw-semibold">${order.product_name || '-'}</div></div></div>
        <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Quantity</small><div class="fw-semibold">${order.quantity || '-'} ${order.unit || ''}</div></div></div>
        <div class="col-12"><div class="p-2 bg-light rounded"><small class="text-muted">Delivery Location</small><div class="fw-semibold">${order.delivery_location || '-'}</div></div></div>
        <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Vehicle No</small><div class="fw-semibold">${dispatch.vehicle_no || '-'}</div></div></div>
        <div class="col-6"><div class="p-2 bg-light rounded"><small class="text-muted">Dispatch Status</small><div class="fw-semibold">${dispatch.dispatch_status || '-'}</div></div></div>
      </div>
    `;
  }

  function loadGoogleMaps(apiKey) {
    return new Promise((resolve, reject) => {
      if (window.google && window.google.maps) return resolve();
      const script = document.createElement('script');
      script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(apiKey)}`;
      script.async = true;
      script.defer = true;
      script.onload = resolve;
      script.onerror = () => reject(new Error('Failed to load Google Maps script'));
      document.head.appendChild(script);
    });
  }

  function initMap() {
    map = new google.maps.Map(mapEl, {
      center: { lat: 20.5937, lng: 78.9629 },
      zoom: 5,
      mapTypeControl: false,
      fullscreenControl: true
    });

    marker = new google.maps.Marker({
      map,
      title: 'Driver location',
      icon: {
        path: google.maps.SymbolPath.FORWARD_CLOSED_ARROW,
        scale: 5,
        fillColor: '#0d6efd',
        fillOpacity: 1,
        strokeColor: '#0d6efd',
        strokeWeight: 2,
        rotation: 0
      }
    });

    pathPolyline = new google.maps.Polyline({
      map,
      path: [],
      geodesic: true,
      strokeColor: '#0d6efd',
      strokeOpacity: 0.9,
      strokeWeight: 3
    });

    mapLoaded = true;
  }

  async function loadConfig() {
    const res = await fetch('/api/tracking/config');
    if (!res.ok) throw new Error('Unable to fetch tracking configuration');
    trackingConfig = await res.json();

    const f = trackingConfig.firebase || {};
    const missingFirebase = !f.apiKey || !f.databaseURL || !f.projectId;
    const missingMaps = !trackingConfig.googleMapsApiKey;

    if (missingFirebase || missingMaps) {
      showConfigError('Tracking config missing. Add FIREBASE_* and GOOGLE_MAPS_API_KEY in .env, then restart server.');
      return false;
    }

    await loadGoogleMaps(trackingConfig.googleMapsApiKey);
    initMap();

    if (!firebase.apps.length) {
      firebase.initializeApp(f);
    }
    db = firebase.database();
    return true;
  }

  async function loadOrderByDriver(driverPhone, preferredOrderId) {
    try {
      const res = await fetch(`/api/dealer/orders/by-driver/${encodeURIComponent(driverPhone)}`);
      if (!res.ok) return setOrderInfo(null);
      const rows = await res.json();
      if (!Array.isArray(rows) || rows.length === 0) return setOrderInfo(null);

      const picked = preferredOrderId
        ? rows.find(r => String(r.order_id) === String(preferredOrderId)) || rows[0]
        : rows[0];
      setOrderInfo(picked);
    } catch (e) {
      setOrderInfo(null);
    }
  }

  function watchDriver(driverPhone) {
    if (!db || !mapLoaded) return;
    if (unsubRef) unsubRef.off();

    const path = `${trackingConfig.trackingPathPrefix || 'driver_locations'}/${driverPhone}`;
    const ref = db.ref(path);
    unsubRef = ref;

    showStatus(`Listening to Firebase path: ${path}`, 'info');

    ref.on('value', (snapshot) => {
      const data = snapshot.val();
      if (!data) {
        showStatus('No live location published yet for this driver.', 'warning');
        return;
      }

      const lat = Number(data.lat);
      const lng = Number(data.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
        showStatus('Invalid coordinates received from Firebase.', 'danger');
        return;
      }

      const pos = { lat, lng };
      marker.setPosition(pos);
      marker.setIcon({
        path: google.maps.SymbolPath.FORWARD_CLOSED_ARROW,
        scale: 5,
        fillColor: '#0d6efd',
        fillOpacity: 1,
        strokeColor: '#0d6efd',
        strokeWeight: 2,
        rotation: Number(data.heading || 0)
      });

      map.panTo(pos);
      map.setZoom(14);

      const pathPoints = pathPolyline.getPath();
      pathPoints.push(pos);

      setTelemetry(data);
      document.getElementById('lastUpdate').textContent = `Last update: ${new Date(data.timestamp || Date.now()).toLocaleString()}`;
      showStatus('Live location updates received.', 'success');
    }, () => {
      showStatus('Firebase listener error. Check database rules and config.', 'danger');
    });
  }

  function generateDriverLink() {
    const mobile = document.getElementById('shareMobile').value.trim();
    if (!mobile) { alert('Please enter the driver mobile number.'); return; }
    const order = document.getElementById('shareOrder').value.trim();
    const vehicle = document.getElementById('shareVehicle').value.trim();
    const link = `${location.origin}/driver/track?phone=${encodeURIComponent(mobile)}`
      + (order ? `&order=${encodeURIComponent(order)}` : '')
      + (vehicle ? `&vehicle=${encodeURIComponent(vehicle)}` : '');
    navigator.clipboard.writeText(link).catch(() => {});
    document.getElementById('openDriverLink').href = link;
    document.getElementById('openDriverLink').classList.remove('d-none');
    const copied = document.getElementById('linkCopied');
    copied.classList.remove('d-none');
    setTimeout(() => copied.classList.add('d-none'), 3000);
    // also pre-fill the track form
    document.getElementById('driverPhone').value = mobile;
    if (order) document.getElementById('orderId').value = order;
  }

  trackForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const driverPhone = document.getElementById('driverPhone').value.trim();
    const orderId = document.getElementById('orderId').value.trim();
    if (!driverPhone) return;

    await loadOrderByDriver(driverPhone, orderId);
    watchDriver(driverPhone);
  });

  (async function init() {
    try {
      const ok = await loadConfig();
      if (!ok) return;

      const defaultPhone = document.getElementById('driverPhone').value.trim();
      const defaultOrder = document.getElementById('orderId').value.trim();
      if (defaultPhone) {
        await loadOrderByDriver(defaultPhone, defaultOrder);
        watchDriver(defaultPhone);
      }
    } catch (e) {
      showStatus(e.message || 'Unable to initialize tracking page.', 'danger');
    }
  })();
</script>

<%- include('../partials/footer') %>
