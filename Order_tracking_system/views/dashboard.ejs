<%- include('partials/header') %>

  <% if (user.role === 'DEALER') { %>
  <!-- Dealer Dashboard -->
  <div class="row g-3">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body py-4">
          <div class="d-flex align-items-center gap-3">
            <div style="font-size:2.5rem">👋</div>
            <div>
              <h4 class="mb-1">Welcome, <%= user.username %>!</h4>
              <p class="text-muted mb-0">Logged in as <strong><%= user.role %></strong> — use the links below to manage your orders.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <a href="/orders" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #0d6efd !important">
          <div class="card-body d-flex align-items-center gap-3 py-4">
            <div style="font-size:2rem">📋</div>
            <div>
              <div class="fw-bold fs-6">My Orders</div>
              <div class="text-muted small">View & place orders, track dispatch</div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/orders?action=new" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #198754 !important">
          <div class="card-body d-flex align-items-center gap-3 py-4">
            <div style="font-size:2rem">🛒</div>
            <div>
              <div class="fw-bold fs-6">Place New Order</div>
              <div class="text-muted small">Submit a new product order</div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #6c757d !important">
        <div class="card-body d-flex align-items-center gap-3 py-4">
          <div style="font-size:2rem">🚛</div>
          <div>
            <div class="fw-bold fs-6">Track Dispatch</div>
            <div class="text-muted small">View real-time dispatch status</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% } else if (user.role === 'ADMIN') { %>
  <!-- Admin Dashboard -->
  <div class="row g-3">
    <div class="col-12">
      <div class="card shadow-sm border-0">
        <div class="card-body py-4">
          <div class="d-flex align-items-center gap-3">
            <div style="font-size:2.5rem">🛡️</div>
            <div>
              <h4 class="mb-1">Welcome, <%= user.username %>!</h4>
              <p class="text-muted mb-0">Logged in as <strong><%= user.role %></strong></p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%# Orders & Dispatch row %>
    <div class="col-12"><h6 class="fw-bold text-muted text-uppercase small mb-0 mt-1">Orders & Dispatch</h6></div>
    <div class="col-md-4">
      <a href="/orders" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #0d6efd !important">
          <div class="card-body d-flex align-items-center gap-3 py-4">
            <div style="font-size:2rem">📊</div>
            <div><div class="fw-bold fs-6">All Orders & Dispatch</div><div class="text-muted small">View all dealer orders &amp; dispatch info</div></div>
          </div>
        </div>
      </a>
    </div>
    <%# Master Data row %>
    <div class="col-12"><h6 class="fw-bold text-muted text-uppercase small mb-0 mt-1">Master Data</h6></div>
    <div class="col-md-3">
      <a href="/master/products" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #0d6efd !important">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div style="font-size:1.6rem">📦</div>
            <div><div class="fw-bold">Products</div><div class="text-muted small">Manage product master</div></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/master/dealers" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #198754 !important">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div style="font-size:1.6rem">🏢</div>
            <div><div class="fw-bold">Dealers</div><div class="text-muted small">Manage dealer master</div></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/master/locations" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #fd7e14 !important">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div style="font-size:1.6rem">📍</div>
            <div><div class="fw-bold">Locations</div><div class="text-muted small">Manage location master</div></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/master/users" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #dc3545 !important">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div style="font-size:1.6rem">👥</div>
            <div><div class="fw-bold">Users</div><div class="text-muted small">Manage users &amp; passwords</div></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/master/user-roles" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #20c997 !important">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div style="font-size:1.6rem">🔑</div>
            <div><div class="fw-bold">User Roles</div><div class="text-muted small">Manage roles &amp; permissions</div></div>
          </div>
        </div>
      </a>
    </div>
    <%# Security & Audit row %>
    <div class="col-12"><h6 class="fw-bold text-muted text-uppercase small mb-0 mt-1">Security & Audit</h6></div>
    <div class="col-md-4">
      <a href="/admin/sessions" class="text-decoration-none">
        <div class="card shadow-sm border-0 h-100" style="border-left:4px solid #6f42c1 !important">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div style="font-size:1.6rem">🔐</div>
            <div><div class="fw-bold">User Sessions &amp; Audit</div><div class="text-muted small">Live sessions &amp; login history report</div></div>
          </div>
        </div>
      </a>
    </div>
  </div>

  <% } else { %>
  <!-- Other roles -->
  <div class="card shadow-sm">
    <div class="card-body">
      <h4>Welcome, <%= user.username %></h4>
      <p class="text-muted">Role: <strong><%= user.role %></strong></p>
      <hr/>
      <p>Your dashboard is being set up. Please contact the admin.</p>
      <a class="btn btn-link" href="/logout">Sign out</a>
    </div>
  </div>
  <% } %>

<%- include('partials/footer') %>
