<%- include('partials/header') %>

  <% if (user.role === 'DEALER') { %>
  <!-- ── Dealer Dashboard ──────────────────────────────────── -->
  <div class="row g-3">
    <div class="col-12">
      <div class="welcome-banner d-flex align-items-center gap-3">
        <div class="avatar-circle">🏬</div>
        <div>
          <h4 class="mb-0 fw-700 text-white">Welcome, <%= user.username %>!</h4>
          <span class="role-tag"><%= user.role %></span>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <a href="/orders" class="dash-card">
        <div class="card card-accent-blue h-100">
          <div class="card-body d-flex align-items-center gap-3 py-4">
            <div class="card-icon" style="background:#eff6ff">📋</div>
            <div>
              <div class="fw-600 fs-6">My Orders</div>
              <div class="text-muted small">View &amp; track your orders</div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/orders?action=new" class="dash-card">
        <div class="card card-accent-green h-100">
          <div class="card-body d-flex align-items-center gap-3 py-4">
            <div class="card-icon" style="background:#f0fdf4">🛒</div>
            <div>
              <div class="fw-600 fs-6">Place New Order</div>
              <div class="text-muted small">Submit a new product order</div>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/tracking" class="dash-card">
        <div class="card card-accent-teal h-100">
          <div class="card-body d-flex align-items-center gap-3 py-4">
            <div class="card-icon" style="background:#f0f9ff">📡</div>
            <div>
              <div class="fw-600 fs-6">Live Tracking</div>
              <div class="text-muted small">Track shipments in real-time</div>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>

  <% } else if (user.role === 'ADMIN') { %>
  <!-- ── Admin Dashboard ───────────────────────────────────── -->
  <div class="row g-3">

    <!-- Welcome banner -->
    <div class="col-12">
      <div class="welcome-banner d-flex align-items-center gap-3">
        <div class="avatar-circle">🛡️</div>
        <div>
          <h4 class="mb-0 fw-700 text-white">Welcome, <%= user.username %>!</h4>
          <span class="role-tag"><%= user.role %></span>
        </div>
      </div>
    </div>

    <!-- Orders & Dispatch -->
    <div class="col-12"><div class="section-label">📊 Orders &amp; Dispatch</div></div>
    <div class="col-md-4">
      <a href="/orders" class="dash-card">
        <div class="card card-accent-blue h-100">
          <div class="card-body d-flex align-items-center gap-3 py-4">
            <div class="card-icon" style="background:#eff6ff">📊</div>
            <div><div class="fw-600 fs-6">All Orders &amp; Dispatch</div><div class="text-muted small">View all dealer orders &amp; dispatch info</div></div>
          </div>
        </div>
      </a>
    </div>

    <!-- Master Data -->
    <div class="col-12"><div class="section-label">🗂️ Master Data</div></div>
    <div class="col-md-3">
      <a href="/master/products" class="dash-card">
        <div class="card card-accent-blue h-100">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div class="card-icon" style="background:#eff6ff">📦</div>
            <div><div class="fw-600">Products</div><div class="text-muted small">Manage product master</div></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/master/dealers" class="dash-card">
        <div class="card card-accent-green h-100">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div class="card-icon" style="background:#f0fdf4">🏢</div>
            <div><div class="fw-600">Dealers</div><div class="text-muted small">Manage dealer master</div></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/master/locations" class="dash-card">
        <div class="card card-accent-amber h-100">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div class="card-icon" style="background:#fffbeb">📍</div>
            <div><div class="fw-600">Locations</div><div class="text-muted small">Manage location master</div></div>
          </div>
        </div>
      </a>
    </div>

    <!-- Users -->
    <div class="col-12"><div class="section-label">👥 Users</div></div>
    <div class="col-md-3">
      <a href="/master/users" class="dash-card">
        <div class="card card-accent-red h-100">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div class="card-icon" style="background:#fef2f2">👤</div>
            <div><div class="fw-600">Login Users</div><div class="text-muted small">Manage users &amp; passwords</div></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/master/user-roles" class="dash-card">
        <div class="card card-accent-teal h-100">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div class="card-icon" style="background:#f0f9ff">🔑</div>
            <div><div class="fw-600">User Roles</div><div class="text-muted small">Manage roles &amp; permissions</div></div>
          </div>
        </div>
      </a>
    </div>

    <!-- Security & Audit -->
    <div class="col-12"><div class="section-label">🔐 Security &amp; Audit</div></div>
    <div class="col-md-4">
      <a href="/admin/sessions" class="dash-card">
        <div class="card card-accent-purple h-100">
          <div class="card-body d-flex align-items-center gap-3 py-3">
            <div class="card-icon" style="background:#faf5ff">🔐</div>
            <div><div class="fw-600">User Sessions &amp; Audit</div><div class="text-muted small">Live sessions &amp; login history report</div></div>
          </div>
        </div>
      </a>
    </div>

  <% } else { %>
  <!-- Other roles -->
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card text-center py-5">
        <div class="card-body">
          <div style="font-size:3rem" class="mb-3">👋</div>
          <h4 class="fw-600">Welcome, <%= user.username %></h4>
          <p class="text-muted">Role: <span class="badge bg-secondary"><%= user.role %></span></p>
          <hr/>
          <p class="text-muted small">Your dashboard is being set up. Please contact the admin.</p>
          <a class="btn btn-outline-primary btn-sm" href="/logout">🚪 Sign out</a>
        </div>
      </div>
    </div>
  </div>
  <% } %>

<%- include('partials/footer') %>

